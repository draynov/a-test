// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EducationLevel {
  SCHOOL
  PROFESSIONAL_BACHELOR
  BACHELOR
  MASTER
  DOCTOR
  DOCTOR_OF_SCIENCES
}

enum ProfessionalQualification {
  V_PKS
  IV_PKS
  III_PKS
  II_PKS
  I_PKS
}

enum AttestationCardType {
  TEACHER
  EDUCATOR
  DIRECTOR
  DEPUTY_DIRECTOR
  PSYCHOLOGIST_COUNSELOR
  REHABILITATOR_TRAINER
}

enum SectionRoman {
  I
  II
  III
  IV
  V
}

enum SectionBWorkflowStatus {
  DRAFT
  ASSESSED_SUBMITTED
  COMMITTEE_IN_PROGRESS
  COMPLETED
}

enum SectionBScore {
  SCORE_1
  SCORE_1_5
  SCORE_2
}

enum CommissionMemberRole {
  PRESIDENT
  INSTITUTION_REP
  RUO_REP
  OPTIONAL
}

enum StaffIdentifierType {
  EGN
  LNCH
  SERVICE_ID
}

enum StaffInstitutionRole {
  INSTITUTION_ADMIN
  STAFF_MEMBER
}

model AttestationCard {
  id                String                  @id @default(cuid())
  cardType          AttestationCardType     @default(TEACHER)
  firstInitial      EducationLevel
  otherAfterInitial EducationLevel?
  baseSpecialty     String?                 @db.VarChar(255)
  hasTeacherQualification Boolean            @default(false)
  hasAdditionalQualification Boolean         @default(false)
  latestProfessionalQualification ProfessionalQualification?
  laborExperienceYears Int                  @default(0)
  teachingExperienceYears Int               @default(0)
  internalQualificationHours Int            @default(0)
  mandatoryQualificationHours Int           @default(0)
  mandatoryQualificationCredits Int         @default(0)
  recommendationsImplemented Boolean        @default(false)
  sectionBTemplateId String?
  sectionBTemplate   SectionBTemplate?      @relation(fields: [sectionBTemplateId], references: [id])
  sectionBStatus     SectionBWorkflowStatus @default(DRAFT)
  sectionBAssessedSystemResponses SectionBAssessedSystemResponse[]
  sectionBAssessedCustomResponses SectionBAssessedCustomResponse[]
  sectionBCommitteeMembers        SectionBCommissionMember[]
  sectionBCommitteeSystemResponses SectionBCommitteeSystemResponse[]
  sectionBCommitteeCustomResponses SectionBCommitteeCustomResponse[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model User {
  id           String                    @id @default(cuid())
  email        String                    @unique
  passwordHash String
  name         String?
  role         String                    @default("USER")
  sectionBCommissionMemberships SectionBCommissionMember[]
  createdInstitutions Institution[]
  staffProfile   Staff?
  sectionBCommitteeSystemResponses SectionBCommitteeSystemResponse[]
  sectionBCommitteeCustomResponses SectionBCommitteeCustomResponse[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model Institution {
  id              String   @id @default(cuid())
  neispuoCode     String   @unique @db.VarChar(50)
  name            String   @db.VarChar(255)
  municipality    String   @db.VarChar(100)
  createdBy       String?
  user            User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  staffMembers    Staff[]
  templates       SectionBTemplate[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdBy])
}

model Staff {
  id               String               @id @default(cuid())
  firstName        String               @db.VarChar(80)
  middleName       String?              @db.VarChar(80)
  lastName         String               @db.VarChar(80)
  identifierType   StaffIdentifierType
  identifierValue  String               @db.VarChar(30)
  institutionId    String
  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  institutionRole  StaffInstitutionRole @default(STAFF_MEMBER)
  userId           String?              @unique
  user             User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([identifierType, identifierValue])
  @@index([institutionId])
  @@index([institutionRole])
}

model SectionBSystemQuestion {
  id          String              @id @default(cuid())
  cardType    AttestationCardType
  sectionRoman SectionRoman
  questionCode String             @db.VarChar(20)
  prompt      String              @db.Text
  displayOrder Int
  maxPoints   Int?
  assessedResponses SectionBAssessedSystemResponse[]
  committeeResponses SectionBCommitteeSystemResponse[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([cardType, questionCode])
  @@unique([cardType, displayOrder])
}

model SectionBTemplate {
  id                    String              @id @default(cuid())
  name                  String              @db.VarChar(150)
  cardType              AttestationCardType
  institutionId         String
  institution           Institution         @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  customQuestions       SectionBCustomQuestion[]
  attestationCards      AttestationCard[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([institutionId, name, cardType])
}

model SectionBCustomQuestion {
  id          String            @id @default(cuid())
  templateId  String
  template    SectionBTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sectionRoman SectionRoman     @default(IV)
  questionCode String           @db.VarChar(20)
  prompt      String            @db.Text
  scoreMethodology1   String    @default("") @db.Text
  scoreMethodology1_5 String    @default("") @db.Text
  scoreMethodology2   String    @default("") @db.Text
  displayOrder Int
  assessedResponses SectionBAssessedCustomResponse[]
  committeeResponses SectionBCommitteeCustomResponse[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([templateId, questionCode])
  @@unique([templateId, displayOrder])
}

model SectionBCommissionMember {
  id                String               @id @default(cuid())
  attestationCardId String
  attestationCard   AttestationCard      @relation(fields: [attestationCardId], references: [id], onDelete: Cascade)
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role              CommissionMemberRole
  displayOrder      Int
  isRequired        Boolean              @default(true)
  systemResponses   SectionBCommitteeSystemResponse[]
  customResponses   SectionBCommitteeCustomResponse[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([attestationCardId, userId])
  @@unique([attestationCardId, displayOrder])
}

model SectionBAssessedSystemResponse {
  id                String               @id @default(cuid())
  attestationCardId String
  attestationCard   AttestationCard      @relation(fields: [attestationCardId], references: [id], onDelete: Cascade)
  questionId        String
  question          SectionBSystemQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  score             SectionBScore
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([attestationCardId, questionId])
}

model SectionBAssessedCustomResponse {
  id                String              @id @default(cuid())
  attestationCardId String
  attestationCard   AttestationCard     @relation(fields: [attestationCardId], references: [id], onDelete: Cascade)
  questionId        String
  question          SectionBCustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  score             SectionBScore
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([attestationCardId, questionId])
}

model SectionBCommitteeSystemResponse {
  id                String                 @id @default(cuid())
  attestationCardId String
  attestationCard   AttestationCard        @relation(fields: [attestationCardId], references: [id], onDelete: Cascade)
  memberId          String
  member            SectionBCommissionMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  evaluatorId       String
  evaluator         User                   @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  questionId        String
  question          SectionBSystemQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  score             SectionBScore
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([memberId, questionId])
}

model SectionBCommitteeCustomResponse {
  id                String                 @id @default(cuid())
  attestationCardId String
  attestationCard   AttestationCard        @relation(fields: [attestationCardId], references: [id], onDelete: Cascade)
  memberId          String
  member            SectionBCommissionMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  evaluatorId       String
  evaluator         User                   @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  questionId        String
  question          SectionBCustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  score             SectionBScore
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([memberId, questionId])
}
